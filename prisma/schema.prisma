generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum ModType {
    BARREL
    GRIP
    MAGAZINE
    OPTIC
    SHIELD
    GENERATOR
    CHIP
}

enum ModRarity {
    PRESTIGE
    SUPERIOR
    DELUXE
    ENHANCED
    STANDARD
}

enum WeaponType {
    ASSAULT_RIFLE
    SMG
    LMG
    PISTOL
    SNIPER_RIFLE
    SHOTGUN
    PRECISION_RIFLE
    RAILGUN
}

enum WeaponSlot {
    PRIMARY
    SECONDARY
    HEAVY
}

enum AmmoType {
    LIGHT_ROUNDS
    HEAVY_ROUNDS
    VOLT_BATTERY
    MIPS_ROUNDS
    VOLT_CELL
}

model Weapon {
    id       String @id @default(cuid())
    name     String @unique
    slug     String @unique
    type     WeaponType
    slot     WeaponSlot
    ammoType AmmoType

    rarity      String?
    price       Int?
    description String?
    imageUrl    String?

    // Combat stats
    firepower           Float?
    damage              Float?
    precisionMultiplier Float?
    rateOfFire          Float?
    range               Float?

    // Accuracy stats
    accuracy          Float?
    hipfireSpread     Float?
    adsSpread         Float?
    crouchSpreadBonus Float?
    movingInaccuracy  Float?

    // Handling stats
    handling    Float?
    equipSpeed  Float?
    adsSpeed    Float?
    reloadSpeed Float?
    weight      Float?
    recoil      Float?
    aimAssist   Float?

    // Magazine/Optics
    magazineSize Int?
    zoom         Float?

    // Special stats
    pelletCount Int?
    spreadAngle Float?
    voltDrain   Float?
    chargeTime  Float?

    mods WeaponMod[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([type])
    @@index([slot])
    @@index([ammoType])
}

model Mod {
    id          String    @id @default(cuid())
    name        String    @unique
    slug        String    @unique
    type        ModType
    rarity      ModRarity
    description String?
    price       Int?
    imageUrl    String?
    isUniversal Boolean   @default(false)
    weapons     WeaponMod[]
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([type])
    @@index([rarity])
}

model WeaponMod {
    id       String @id @default(cuid())
    weapon   Weapon @relation(fields: [weaponId], references: [id])
    weaponId String
    mod      Mod    @relation(fields: [modId], references: [id])
    modId    String

    @@unique([weaponId, modId])
    @@index([weaponId])
    @@index([modId])
}

model Submission {
    id        String   @id @default(cuid())
    message   String   @db.VarChar(180)
    imageUrl  String
    pageUrl   String?
    status    String   @default("pending")
    createdAt DateTime @default(now())
}
