generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum ModType {
    BARREL
    GRIP
    MAGAZINE
    OPTIC
    SHIELD
    GENERATOR
    CHIP
}

enum ModRarity {
    PRESTIGE
    SUPERIOR
    DELUXE
    ENHANCED
    STANDARD
}

enum WeaponType {
    ASSAULT_RIFLE
    SMG
    LMG
    PISTOL
    SNIPER_RIFLE
    SHOTGUN
    PRECISION_RIFLE
    RAILGUN
}

enum WeaponSlot {
    PRIMARY
    SECONDARY
    HEAVY
}

enum AmmoType {
    LIGHT_ROUNDS
    HEAVY_ROUNDS
    VOLT_BATTERY
    MIPS_ROUNDS
    VOLT_CELL
}

model Weapon {
    id       String @id @default(cuid())
    name     String @unique
    slug     String @unique
    type     WeaponType
    slot     WeaponSlot
    ammoType AmmoType

    rarity      String?
    price       Int?
    description String?
    imageUrl    String?

    // Combat stats
    firepower           Float?
    damage              Float?
    precisionMultiplier Float?
    rateOfFire          Float?
    range               Float?

    // Accuracy stats
    accuracy          Float?
    hipfireSpread     Float?
    adsSpread         Float?
    crouchSpreadBonus Float?
    movingInaccuracy  Float?

    // Handling stats
    handling    Float?
    equipSpeed  Float?
    adsSpeed    Float?
    reloadSpeed Float?
    weight      Float?
    recoil      Float?
    aimAssist   Float?

    // Magazine/Optics
    magazineSize Int?
    zoom         Float?

    // Special stats
    pelletCount Int?
    spreadAngle Float?
    voltDrain   Float?
    chargeTime  Float?

    mods    WeaponMod[]
    builds  Build[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([type])
    @@index([slot])
    @@index([ammoType])
}

model Mod {
    id          String    @id @default(cuid())
    name        String    @unique
    slug        String    @unique
    type        ModType
    rarity      ModRarity
    description String?
    price       Int?
    imageUrl    String?
    isUniversal Boolean   @default(false)
    weapons     WeaponMod[]
    buildMods   BuildMod[]
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([type])
    @@index([rarity])
}

model WeaponMod {
    id       String @id @default(cuid())
    weapon   Weapon @relation(fields: [weaponId], references: [id])
    weaponId String
    mod      Mod    @relation(fields: [modId], references: [id])
    modId    String

    @@unique([weaponId, modId])
    @@index([weaponId])
    @@index([modId])
}

model Submission {
    id        String   @id @default(cuid())
    message   String   @db.VarChar(180)
    imageUrl  String
    pageUrl   String?
    status    String   @default("pending")
    createdAt DateTime @default(now())
}

// NextAuth models
model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    builds        Build[]
    votes         BuildVote[]
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?
    refresh_expires_in Int?
    membership_id     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

enum BuildType {
    PVP
    PVE
    PVEVP
}

model Build {
    id       String    @id @default(cuid())
    title    String    @db.VarChar(100)
    type     BuildType
    weapon   Weapon    @relation(fields: [weaponId], references: [id])
    weaponId String
    author   User      @relation(fields: [authorId], references: [id])
    authorId String
    score    Int       @default(0)
    mods     BuildMod[]
    votes    BuildVote[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([weaponId, score])
}

model BuildMod {
    id      String  @id @default(cuid())
    build   Build   @relation(fields: [buildId], references: [id], onDelete: Cascade)
    buildId String
    mod     Mod     @relation(fields: [modId], references: [id])
    modId   String
    modType ModType

    @@unique([buildId, modType])
    @@index([buildId])
}

model BuildVote {
    id      String @id @default(cuid())
    build   Build  @relation(fields: [buildId], references: [id], onDelete: Cascade)
    buildId String
    user    User   @relation(fields: [userId], references: [id])
    userId  String
    value   Int

    @@unique([buildId, userId])
    @@index([buildId])
}
